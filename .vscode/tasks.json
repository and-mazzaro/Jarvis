{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Jarvis Backend",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe backend/main.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Sync frontend/dist",
      "type": "shell",
      "command": "xcopy /E /Y /I frontend\\src\\* frontend\\dist\\ > nul && echo Synced.",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Start Electron",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build Installer",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    }
  ]
}
